---
import type { Publication } from "../data/publications";
const { pub } = Astro.props as { pub: Publication };
---

<article class="pub-card">
  <h3>{pub.title}</h3>
  <p class="authors">{pub.authors}</p>
  <p class="venue">{pub.venue} · {pub.year}</p>
  <details class="abstract-details">
    <summary>Abstract</summary>
    <p class="abstract">{pub.abstract}</p>
  </details>
  <div class="links">
    {pub.links.arxiv && <a href={pub.links.arxiv} target="_blank" rel="noopener noreferrer">arXiv</a>}
    {pub.links.openreview && <a href={pub.links.openreview} target="_blank" rel="noopener noreferrer">OpenReview</a>}
    {pub.links.pdf && <a href={pub.links.pdf} target="_blank" rel="noopener noreferrer">PDF</a>}
  </div>
</article>

<style>
  .pub-card {
    border-left: 3px solid var(--card-border);
    padding: 1.25rem 1.5rem;
    margin-bottom: 2rem;
    background: var(--card-bg);
    border-radius: 0 6px 6px 0;
  }
  h3 { margin: 0 0 0.35rem; font-size: 1.08rem; font-weight: 600; color: var(--text); line-height: 1.35; }
  .authors { margin: 0; color: var(--muted-text); font-size: 0.9rem; }
  .venue { margin: 0.2rem 0 0.75rem; font-size: 0.85rem; color: var(--muted-text); font-style: italic; }
  .abstract { font-size: 0.9rem; line-height: 1.6; color: var(--text); margin-top: 0.5rem; }
  .abstract-details summary {
    cursor: pointer;
    font-size: 0.85rem;
    color: var(--muted-text);
    list-style: none;
  }
  .abstract-details summary::-webkit-details-marker { display: none; }
  .abstract-details summary::before { content: "▸ "; }
  .abstract-details[open] summary::before { content: "▾ "; }
  .abstract-details summary:focus-visible {
    outline: 2px solid #111;
    outline-offset: 2px;
  }
  .links { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 0.75rem; }
  .links a {
    font-size: 0.8rem;
    padding: 0.35rem 0.75rem;
    background: var(--card-link-bg);
    color: var(--card-link-text);
    border-radius: 999px;
    text-decoration: none;
  }
  .links a:hover {
    filter: brightness(1.1);
  }
  .links a:focus-visible {
    outline: 2px solid #111;
    outline-offset: 2px;
  }
</style>
