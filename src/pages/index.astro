---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import PublicationCard from "../components/PublicationCard.astro";
import { publications } from "../data/publications";

const sortedPubs = [...publications].sort((a, b) => b.year - a.year);
const blogEntries = await getCollection("blog", ({ data }) => !data.draft);
const sortedPosts = blogEntries.sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

const formatDate = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });
---

<Base
  title="Scott Biggs"
  description="Scott Biggs — MS in AI student and researcher at Northeastern University. Research interests: reinforcement learning, diffusion and flow matching, weight space generation."
>
  <img slot="banner" src="/banner.jpeg" alt="" />

  <header class="intro">
    <h1>Scott Biggs</h1>
    <p class="tagline">MS in AI Student / Researcher — Northeastern University</p>

    <nav class="top-nav" aria-label="Profiles and links">
      <div class="top-nav-links">
        <a href="https://github.com/ScottBiggs2" target="_blank" rel="noopener noreferrer">GitHub</a>
        <a href="https://huggingface.co/ScottBiggs2" target="_blank" rel="noopener noreferrer">HuggingFace</a>
        <a href="https://scholar.google.com/citations?hl=en&user=CH66jrwAAAAJ" target="_blank" rel="noopener noreferrer">Google Scholar</a>
        <a href="https://www.linkedin.com/in/scott-biggs-112970255" target="_blank" rel="noopener noreferrer">LinkedIn</a>
      </div>
      <button
        type="button"
        class="theme-toggle"
        data-theme-toggle
        aria-pressed="false"
      >
        Dark mode
      </button>
    </nav>
  </header>

  <div class="page-layout">
    <aside class="side-nav" aria-label="Page sections">
      <a href="#about">Intro</a>
      <a href="#publications">Research</a>
      <a href="#blog">Blog</a>
    </aside>

    <div class="page-main">
      <section id="about">
        <h2>About</h2>
        <p>
          Hi everyone, I'm Scott. Currently, I'm an MS in AI student at Northeastern University in Silicon Valley.
          I have research and startup experience, and my ongoing research interests include reinforcement learning, diffusion and flow matching models, and weight space generation and analysis.
        </p>
      </section>

      <section id="publications">
        <h2>Publications</h2>
        {sortedPubs.map((pub) => <PublicationCard pub={pub} />)}
      </section>

      <section id="blog">
        <h2>Blog</h2>
        {
          sortedPosts.length === 0 ? (
            <p class="blog-empty">
              I occasionally write about papers I'm reading and projects I'm working on.
              I'll start adding posts here soon.
            </p>
          ) : (
            <ul class="blog-list">
              {sortedPosts.map((post) => (
                <li class="blog-item">
                  <h3>
                    <a href={`/blog/${post.id}`}>{post.data.title}</a>
                  </h3>
                  <p class="blog-meta">{formatDate(post.data.pubDate)}</p>
                  <p class="blog-summary">{post.data.description}</p>
                  <a href={`/blog/${post.id}`}>Read post</a>
                </li>
              ))}
            </ul>
          )
        }
      </section>
    </div>
  </div>

  <style>
    .intro {
      margin-bottom: 1.5rem;
    }

    .top-nav {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: space-between;
      gap: 0.75rem 1rem;
      margin-top: 0.75rem;
    }

    .top-nav-links {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      font-size: 0.9rem;
    }

    .theme-toggle {
      font-size: 0.8rem;
      padding: 0.3rem 0.85rem;
      border-radius: 999px;
      border: 1px solid var(--border-subtle);
      background: transparent;
      color: var(--text);
      cursor: pointer;
    }

    .theme-toggle:hover {
      background: var(--surface);
    }

    .theme-toggle:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 2px;
    }

    .page-layout {
      display: grid;
      grid-template-columns: minmax(0, 1fr);
      gap: 2rem;
    }

    .side-nav {
      display: flex;
      flex-direction: row;
      gap: 0.75rem;
      font-size: 0.85rem;
      border-bottom: 1px solid var(--border-subtle);
      padding-bottom: 0.75rem;
    }

    .side-nav a {
      text-decoration: none;
      color: var(--muted-text);
    }

    .side-nav a:hover {
      color: var(--link);
      text-decoration: underline;
    }

    .page-main {
      min-width: 0;
    }

    @media (min-width: 900px) {
      .page-layout {
        grid-template-columns: 180px minmax(0, 1fr);
        align-items: flex-start;
      }

      .side-nav {
        flex-direction: column;
        position: sticky;
        top: 1.5rem;
        border-bottom: none;
        padding-bottom: 0;
      }
    }

    .blog-empty {
      font-size: 0.9rem;
      color: var(--muted-text);
    }

    .blog-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .blog-item h3 {
      margin: 0 0 0.25rem;
      font-size: 1rem;
    }

    .blog-item h3 a {
      text-decoration: none;
      color: var(--text);
    }

    .blog-item h3 a:hover {
      text-decoration: underline;
    }

    .blog-meta {
      margin: 0 0 0.5rem;
      font-size: 0.8rem;
      color: var(--muted-text);
    }

    .blog-summary {
      margin: 0 0 0.5rem;
      font-size: 0.9rem;
    }

    .blog-item a {
      font-size: 0.85rem;
    }
  </style>

</Base>